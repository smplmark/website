{
  "name": "smplmark-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "smplmark website — the marketing site and published-benchmark viewer on Cloudflare Workers",
  "scripts": {
    "dev": "wrangler dev --port ${PORT:-8787}",
    "deploy": "wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@vitest/coverage-istanbul": "^4.1.9",
    "typescript": "^6.0.3",
    "uplot": "^1.6.32",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.1.0"
  }
}
